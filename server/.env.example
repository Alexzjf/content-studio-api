# ── Production checklist (shared bot for many users) ─────────────
#
# 1) GEMINI_API_KEYS — мінімум 2–3 ключі з РІЗНИХ Google-акаунтів
#    (aistudio.google.com/apikey). Один ключ = ліміти й «high demand».
#
# 2) У Google Cloud увімкніть billing для проєкту (pay-as-you-go).
#    Без billing безкоштовний tier дуже швидко дає 429.
#
# 3) Koyeb Free — work directory: server, Instance: Free (Frankfurt)
#
# 4) GEMINI_MODEL=gemini-2.5-flash (НЕ flash-lite — часто перевантажена).
#
# 5) UptimeRobot / cron: GET https://YOUR-SERVICE.onrender.com/health кожні 5 хв.
#
# ── Keys ─────────────────────────────────────────────────────────

# Один ключ (мінімум для dev):
GEMINI_API_KEY=

# Кілька ключів через кому (рекомендовано для продакшену):
# GEMINI_API_KEYS=AIza...,AIza...,AIza...

PORT=8787

# ── Auth (Google / Telegram / X) ─────────────────────────────────
AUTH_JWT_SECRET=change-this-auth-secret-min-32-chars
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
GOOGLE_CLIENT_ID=
X_CLIENT_ID=

# Ліміт на одного користувача розширення на день (захист від зловживань)
DAILY_LIMIT_PER_CLIENT=300

# Адмін-панель користувачів: https://YOUR-SERVICE/admin
ADMIN_SECRET=change-this-admin-secret-min-16-chars

# Google Sheets CRM (див. GOOGLE_SHEETS_CRM.md)
GOOGLE_SHEETS_ID=
# JSON service account (одним рядком або base64):
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Модель на сервері
GEMINI_MODEL=gemini-2.5-flash

# Скільки мс сервер сам повторює запит до Gemini, перш ніж віддати помилку клієнту
INTERNAL_RETRY_MS=90000

# Пауза для ключа після 429 (мс), потім знову в ротації
KEY_COOLDOWN_MS=30000

# ── Stripe (card payments) ─────────────────────────────────────
# 1) Реєстрація: https://dashboard.stripe.com/register
# 2) Developers → API keys → Secret key (sk_live_... або sk_test_...)
# 3) Developers → Webhooks → Add endpoint:
#    URL: PUBLIC_API_URL/billing/webhook/stripe
#    Events: checkout.session.completed
#    → скопіюйте Signing secret (whsec_...)
PUBLIC_API_URL=https://content-studio-api-1.onrender.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
