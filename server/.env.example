# Your Gemini key (never put this in the extension)
GEMINI_API_KEY=

# Render/Railway set PORT automatically
PORT=8787

# Max AI requests per browser install per day
DAILY_LIMIT_PER_CLIENT=300

# Default Gemini model on the server (gemini-2.5-flash is most reliable on free tier)
GEMINI_MODEL=gemini-2.5-flash

# Optional: several keys comma-separated — rotation when one hits quota
# GEMINI_API_KEYS=key1,key2
