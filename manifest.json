{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.42.5",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "offscreen", "scripting", "windows", "tabs", "sidePanel", "system.display", "identity"],
  "oauth2": {
    "client_id": "885065993868-0fpub31tvtk0d7q6s58559upkljun8e7.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": [
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "https://content-studio-api-1.onrender.com/*",
    "https://content-studio-api.onrender.com/*",
    "https://*.onrender.com/*",
    "https://*.koyeb.app/*",
    "https://*.zeabur.app/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.twitter.com/*",
    "https://video.twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.groq.com/*",
    "https://api.mistral.ai/*",
    "https://api.deepseek.com/*",
    "https://api.cursor.com/*"
  ],
  "action": {
    "default_title": "cheatXtwitter",
    "default_popup": "app.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "app.html?side=1"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["audio-extract.js", "content.js", "x-comment.js", "page-panel.js"],
      "css": ["x-comment.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://chrome.google.com/*",
        "https://chromewebstore.google.com/*"
      ],
      "js": ["page-panel.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "app.html",
        "auth-telegram.html",
        "oauth-setup.html",
        "auth-config.local.js",
        "page-panel.js",
        "audio-store.js",
        "x-page-fill.js",
        "wasm/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
